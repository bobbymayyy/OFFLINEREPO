#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CFG="${CFG:-$HERE/config.yml}"

log() { printf "%s\n" "$*" | tee -a "$HERE/logs/offline-repoctl.log" >/dev/null; }

if command -v apt >/dev/null 2>&1; then
  sudo apt update
  sudo apt install -y \
    podman \
    rsync \
    dialog \
    python3 \
    python3-yaml
elif command -v dnf >/dev/null 2>&1; then
  sudo dnf update
  sudo dnf install -y \
    podman \
    rsync \
    dialog \
    python3 \
    python3-pyyaml
else
  echo "Unsupported host: need apt or dnf" >&2
  exit 1
fi

need() {
  command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1" >&2; exit 1; }
}

detect_engine() {
  if command -v docker >/dev/null 2>&1; then echo "docker"; return; fi
  if command -v podman >/dev/null 2>&1; then echo "podman"; return; fi
  echo "none"
}

require_image() {
  local engine="$1"
  local image="$2"

  if ! "$engine" image inspect "$image" >/dev/null 2>&1; then
    echo "Required image not found in $engine image store: $image" >&2
    return 1
  fi
}

py_get() {
  # Usage: py_get 'paths.repo_root'
  python3 - "$1" "$CFG" <<'PY'
import sys, yaml
path = sys.argv[1].split(".")
cfg = yaml.safe_load(open(sys.argv[2],"r"))
cur = cfg
for p in path:
  if cur is None: break
  cur = cur.get(p) if isinstance(cur, dict) else None
print("" if cur is None else cur)
PY
}

py_bool_any_enabled() {
  # Usage: py_bool_any_enabled 'apt' or 'rpm' or 'apk'
  python3 - "$1" "$CFG" <<'PY'
import sys, yaml
k = sys.argv[1]
cfg = yaml.safe_load(open(sys.argv[2],"r"))
items = cfg.get(k, [])
print("yes" if any(d.get("enabled", False) for d in items) else "no")
PY
}

py_enabled_rpm_names() {
  # Usage: redirect to function
  python3 - "$CFG" <<'PY'
import sys, yaml
cfg = yaml.safe_load(open(sys.argv[1], "r")) or {}
for d in cfg.get("rpm", []):
    if d.get("enabled", False):
        name = str(d.get("name", "")).strip()
        if name:
            print(name)
PY
}

container_run() {
  local image="$1"; shift
  local engine; engine="$(detect_engine)"
  [[ "$engine" != "none" ]] || { echo "Need podman or docker installed." >&2; exit 1; }

  local repo_root; repo_root="$(py_get paths.repo_root)"
  [[ -n "$repo_root" ]] || { echo "paths.repo_root is empty in config.yml" >&2; exit 1; }

  mkdir -p "$repo_root"/{apt,rpm,apk,logs,keys}

  local repo_mount="$repo_root:/repo"
  if [[ "$engine" == "podman" ]] && command -v getenforce >/dev/null 2>&1; then
    if [[ "$(getenforce 2>/dev/null || true)" != "Disabled" ]]; then
      repo_mount="$repo_root:/repo:Z"
    fi
  fi

  "$engine" run --rm -t \
    -e CFG=/work/config.yml \
    -e REPO_ROOT=/repo \
    -v "$CFG":/work/config.yml:ro \
    -v "$HERE/lib":/work/lib:ro \
    -v "$repo_mount" \
    -w /work \
    "$image" "$@"
}

sync_apt() {
  local img; img="$(py_get containers.debian_image)"
  [[ -n "$img" ]] || { echo "containers.debian_image missing" >&2; exit 1; }
  mkdir -p "$HERE/logs"
  log "[INFO] starting APT sync with image: $img"
  if container_run "$img" /work/lib/sync_apt.py |& tee -a "$HERE/logs/sync_apt.log"; then
    log "[INFO] completed APT sync successfully"
  else
    log "[ERROR] APT sync failed"
    return 1
  fi
}

sync_rpm() {
  local distro
  while IFS= read -r distro; do
    [[ -n "$distro" ]] || continue
    local img=""
    case "$distro" in
      fedora)
        img="$(py_get containers.fedora_image)"
        ;;
      rocky)
        img="$(py_get containers.rocky_image)"
        ;;
      rhel)
        log "[WARN] skipping RHEL sync for now: requires special entitlement/subscription mode"
        continue
        ;;
      *)
        log "[WARN] no RPM image mapping defined for distro: $distro"
        continue
        ;;
    esac
    [[ -n "$img" ]] || {
      log "[ERROR] missing image config for RPM distro: $distro"
      return 1
    }
    log "[INFO] starting RPM sync for $distro with image: $img"
    if container_run "$img" env ONLY_RPM_NAME="$distro" /work/lib/sync_rpm.py |& tee -a "$HERE/logs/sync_rpm.log"; then
      log "[INFO] completed RPM sync for $distro successfully"
    else
      log "[ERROR] RPM sync failed for $distro"
      return 1
    fi
  done < <(py_enabled_rpm_names)
}

sync_apk() {
  # can run in either image; using fedora by default
  local img; img="$(py_get containers.fedora_image)"
  [[ -n "$img" ]] || { echo "containers.fedora_image missing" >&2; exit 1; }
  mkdir -p "$HERE/logs"
  log "[INFO] starting APK sync with image: $img"
  if container_run "$img" /work/lib/sync_apk.sh |& tee -a "$HERE/logs/sync_apk.log"; then
    log "[INFO] completed APK sync successfully"
  else
    log "[ERROR] APK sync failed"
    return 1
  fi
}

sync_permanent() {
  local repo_root permanent
  repo_root="$(py_get paths.repo_root)"
  permanent="$(py_get paths.permanent_root)"

  [[ -n "$permanent" ]] || return 0
  need rsync

  mkdir -p "$permanent"
  rsync -aH --delete "$repo_root"/ "$permanent"/ |& tee -a "$HERE/logs/sync_permanent.log"
}

export_snippets() {
  local base; base="$(py_get paths.publish_url_base)"
  local repo_root; repo_root="$(py_get paths.repo_root)"

  cat <<EOF
# Base URL:
#   $base
#
# Repo root on server filesystem:
#   $repo_root
#
# APT clients (examples):
#   Add a key to /usr/share/keyrings/offline-repo.gpg (you manage keys per upstream)
#   Then add lines like:
#     deb [signed-by=/usr/share/keyrings/offline-repo.gpg] $base/apt/debian bookworm main contrib non-free non-free-firmware
#
# RPM clients (example .repo):
#   [fedora-updates-offline]
#   name=Fedora Updates (offline)
#   baseurl=$base/rpm/fedora/41/updates/
#   enabled=1
#   gpgcheck=0
#
# Alpine clients (/etc/apk/repositories):
#   $base/apk/alpine/alpine-v3.21-main
#   $base/apk/alpine/alpine-v3.21-community
EOF
}

show_config() {
  ${EDITOR:-nano} "-v" "$CFG"
}

edit_config() {
  ${EDITOR:-nano} "$CFG"
}

sync_all() {
  mkdir -p "$HERE/logs"
  log "[INFO] sync_all started"
  local any

  any="$(py_bool_any_enabled apt)"
  [[ "$any" == "yes" ]] && sync_apt

  any="$(py_bool_any_enabled rpm)"
  [[ "$any" == "yes" ]] && sync_rpm

  any="$(py_bool_any_enabled apk)"
  [[ "$any" == "yes" ]] && sync_apk

  sync_permanent
  log "[INFO] sync_all finished"
}

tui() {
  need dialog
  while true; do
    local choice
    choice=$(dialog --clear --stdout --title "offline-repoctl" \
      --menu "Portable multi-distro repo mirror" 0 0 0 \
      1 "View current configuration" \
      2 "Edit configuration" \
      3 "Sync repos now (containers default)" \
      4 "View logs (tail)" \
      5 "Export client setup snippets" \
      6 "Exit") || true

    case "${choice:-6}" in
      1) show_config ;;
      2) edit_config ;;
      3) dialog --infobox "Sync running... (check logs afterward)" 5 60; sync_all; dialog --msgbox "Sync complete." 6 40 ;;
      4) dialog --title "logs/offline-repoctl.log" --msgbox "$(tail -n 200 "$HERE/logs/offline-repoctl.log" 2>/dev/null || echo '(no log yet)')" 0 0 ;;
      5) dialog --title "client snippets" --msgbox "$(export_snippets)" 0 0 ;;
      6) clear; exit 0 ;;
    esac
  done
}

case "${1:-}" in
  tui) tui ;;
  sync) sync_all ;;
  show-config) show_config ;;
  edit-config) edit_config ;;
  export-snippets) export_snippets ;;
  *)
    cat <<EOF
Usage:
  $0 tui
  $0 sync
  $0 show-config
  $0 edit-config
  $0 export-snippets

Tips:
  - Build images once:
      podman build -t offline-repo/debian-apt:stable -f containers/Dockerfile.debian containers
      podman build -t offline-repo/fedora-rpm:latest -f containers/Dockerfile.fedora containers
      OR
      docker build ...
  - Then run:
      $0 tui
EOF
    ;;
esac
